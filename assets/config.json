{
  "device": "cpu",
  "outDir": "out",
  "useGpu": false,
  "models": {
    "asr":  { "const": "WHISPER_TINY",                       "type": "whisper" },
    "tts":  { "const": "TTS_MULTILINGUAL_SUPERTONIC3_Q8_0",  "type": "tts", "engine": "supertonic" },
    "ttsEnFallback": { "const": "TTS_EN_SUPERTONIC_Q8_0",    "type": "tts", "engine": "supertonic" },
    "nmt":  { "const": "BERGAMOT_EN_ES", "constTemplate": "BERGAMOT_${SRC}_${TGT}", "type": "nmt", "engine": "Bergamot", "pivot": "en" }
  },
  "lang": { "source": "en", "target": "es" },
  "room": {
    "topic": "tifo-match-room-v1",
    "maxMessageBytes": 4096,
    "bootstrap": ["192.168.1.105:49737"],
    "speak": false
  },
  "ui": {
    "sourceFlag": "🇬🇧",
    "sourceLabel": "English",
    "languages": [
      { "code": "it", "label": "Italiano", "flag": "🇮🇹", "rtl": false },
      { "code": "es", "label": "Español",  "flag": "🇪🇸", "rtl": false },
      { "code": "hi", "label": "हिन्दी",    "flag": "🇮🇳", "rtl": false },
      { "code": "ar", "label": "العربية",   "flag": "🇸🇦", "rtl": true  },
      { "code": "pt", "label": "Português", "flag": "🇧🇷", "rtl": false },
      { "code": "fr", "label": "Français",  "flag": "🇫🇷", "rtl": false }
    ]
  },
  "audio": { "asrSampleRate": 16000, "ttsSampleRate": 44100 },
  "sample": {
    "commentary": "And it's a goal! An absolute thunderbolt from outside the box in the final minute of the match!",
    "commentaryLines": [
      "Kickoff! The home side gets us underway in this final.",
      "A beautiful through ball splits the defense wide open.",
      "He shoots, and it's a goal! An absolute thunderbolt in the final minute!",
      "What a moment for these supporters around the world."
    ]
  },
  "stream": {
    "chunkMs": 100,
    "paceRealtime": true,
    "gapMs": 700,
    "vad": "VAD_SILERO_5_1_2",
    "vadParams": {
      "threshold": 0.6,
      "min_speech_duration_ms": 300,
      "min_silence_duration_ms": 600,
      "max_speech_duration_s": 15.0,
      "speech_pad_ms": 200
    },
    "asrThreads": 4,
    "ttsSpeed": 1.05,
    "ttsSteps": 5,
    "asrParams": { "strategy": "greedy", "no_timestamps": true, "suppress_blank": true, "suppress_nst": true, "temperature": 0.0 }
  }
}
